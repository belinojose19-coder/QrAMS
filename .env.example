# Example environment variables
# Replace the DATABASE_URL with your Neon/Postgres connection string
DATABASE_URL="postgresql://user:password@host:5432/database"
NODE_ENV=development
SESSION_COOKIE_NAME=qrams_session
SESSION_TTL_DAYS=7
# Keys required for QR encryption and HMAC signing
# Use a 32-byte base64 or hex string for QR_ENCRYPTION_KEY (AES-256)
QR_ENCRYPTION_KEY=
# Use a strong random key for HMAC (hex or base64)
QR_SECRET_KEY=
